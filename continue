// ==================== RECEIPT PRINTING SERVICE ====================

class ReceiptService {
  static Future<void> printReceipt(Booking booking) async {
    final pdf = pw.Document();
    final now = DateTime.now();
    final formattedDate = DateFormat('MMMM dd, yyyy').format(now);
    final formattedTime = DateFormat('hh:mm a').format(now);

    pdf.addPage(
      pw.Page(
        pageFormat: PdfPageFormat.roll80,
        build: (context) => pw.Column(
          crossAxisAlignment: pw.CrossAxisAlignment.center,
          children: [
            pw.Text('FRESH WAVE LAUNDRY', style: pw.TextStyle(fontSize: 16, fontWeight: pw.FontWeight.bold)),
            pw.Text('F. Delima St, Lumbia, CDO', style: pw.TextStyle(fontSize: 10)),
            pw.Text('Misamis Oriental, 9000', style: pw.TextStyle(fontSize: 10)),
            pw.Text('Tel: 0906-253-9218', style: pw.TextStyle(fontSize: 10)),
            pw.Divider(),
            pw.Text('OFFICIAL RECEIPT', style: pw.TextStyle(fontSize: 12, fontWeight: pw.FontWeight.bold)),
            pw.SizedBox(height: 5),
            pw.Align(
              alignment: pw.Alignment.centerLeft,
              child: pw.Text('Order #: ${booking.id}', style: pw.TextStyle(fontSize: 10)),
            ),
            pw.Align(
              alignment: pw.Alignment.centerLeft,
              child: pw.Text('Date: $formattedDate', style: pw.TextStyle(fontSize: 10)),
            ),
            pw.Align(
              alignment: pw.Alignment.centerLeft,
              child: pw.Text('Time: $formattedTime', style: pw.TextStyle(fontSize: 10)),
            ),
            pw.Divider(),
            pw.Align(
              alignment: pw.Alignment.centerLeft,
              child: pw.Text('Customer: ${booking.customerName}', style: pw.TextStyle(fontSize: 10)),
            ),
            pw.Align(
              alignment: pw.Alignment.centerLeft,
              child: pw.Text('Contact: ${booking.phone}', style: pw.TextStyle(fontSize: 10)),
            ),
            pw.Align(
              alignment: pw.Alignment.centerLeft,
              child: pw.Text('Address: ${booking.street}, ${booking.barangay}', style: pw.TextStyle(fontSize: 10)),
            ),
            pw.Divider(),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('Service:', style: pw.TextStyle(fontSize: 10)),
                pw.Text(booking.serviceType, style: pw.TextStyle(fontSize: 10)),
              ],
            ),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('Load:', style: pw.TextStyle(fontSize: 10)),
                pw.Text('${booking.loadKg} kg', style: pw.TextStyle(fontSize: 10)),
              ],
            ),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('Detergent:', style: pw.TextStyle(fontSize: 10)),
                pw.Text(booking.detergent, style: pw.TextStyle(fontSize: 10)),
              ],
            ),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('Fabric:', style: pw.TextStyle(fontSize: 10)),
                pw.Text(booking.fabric, style: pw.TextStyle(fontSize: 10)),
              ],
            ),
            pw.Divider(),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('Subtotal:', style: pw.TextStyle(fontSize: 10)),
                pw.Text('₱${booking.totalPrice.toStringAsFixed(2)}', style: pw.TextStyle(fontSize: 10)),
              ],
            ),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('Add-ons:', style: pw.TextStyle(fontSize: 10)),
                pw.Text('₱40.00', style: pw.TextStyle(fontSize: 10)),
              ],
            ),
            pw.Divider(),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('TOTAL', style: pw.TextStyle(fontSize: 12, fontWeight: pw.FontWeight.bold)),
                pw.Text('₱${(booking.totalPrice + 40).toStringAsFixed(2)}', style: pw.TextStyle(fontSize: 12, fontWeight: pw.FontWeight.bold)),
              ],
            ),
            pw.SizedBox(height: 5),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('Payment:', style: pw.TextStyle(fontSize: 9)),
                pw.Text(booking.paymentMethod, style: pw.TextStyle(fontSize: 9)),
              ],
            ),
            pw.Row(
              mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
              children: [
                pw.Text('Type:', style: pw.TextStyle(fontSize: 9)),
                pw.Text(booking.orderType!, style: pw.TextStyle(fontSize: 9)),
              ],
            ),
            pw.Divider(),
            pw.Text('Thank you for choosing Fresh Wave!', style: pw.TextStyle(fontSize: 9)),
            pw.Text('Estimated ready: 24 hours', style: pw.TextStyle(fontSize: 9)),
            pw.SizedBox(height: 10),
            pw.BarcodeWidget(
              barcode: pw.Barcode.qrCode(),
              data: booking.id,
              width: 80,
              height: 80,
            ),
          ],
        ),
      ),
    );

    await Printing.layoutPdf(
      onLayout: (format) async => pdf.save(),
      name: 'FreshWave_Receipt_${booking.id}',
    );
  }
}
