class BookingScreen extends StatefulWidget {
  const BookingScreen({super.key});

  @override
  State<BookingScreen> createState() => _BookingScreenState();
}

class _BookingScreenState extends State<BookingScreen> {
  final pageController = PageController();
  int currentPage = 0;

  final fullNameController = TextEditingController();
  final phoneController = TextEditingController();
  final barangayController = TextEditingController();
  final cityController = TextEditingController();
  final streetController = TextEditingController();
  final notesController = TextEditingController();

  String? selectedService;
  String? selectedDetergent;
  String? selectedFabric;
  String? selectedPayment;
  double loadKg = 3;

  final services = ['Wash + Dry + Fold', 'Wash + Dry', 'Wash Only', 'Spin + Dry + Fold', 'Spin + Dry', 'Spin Only'];
  final detergents = ['Surf', 'Ariel', 'Tide', 'Breeze'];
  final fabrics = ['Downy', 'Comfort', 'Lenor'];
  final payments = ['Cash on Delivery', 'GCash', 'Maya', 'Bank Transfer'];

  @override
  void initState() {
    super.initState();
    final user = AuthService().currentUser!;
    fullNameController.text = user.fullName;
    phoneController.text = user.phone;
    barangayController.text = user.barangay ?? '';
    cityController.text = user.city ?? 'Cagayan de Oro';
    streetController.text = user.street ?? '';
  }

  void _nextPage() {
    if (_validatePage()) {
      if (currentPage < 2) {
        pageController.nextPage(duration: const Duration(milliseconds: 300), curve: Curves.easeInOut);
        setState(() => currentPage++);
      }
    }
  }

  void _prevPage() {
    if (currentPage > 0) {
      pageController.previousPage(duration: const Duration(milliseconds: 300), curve: Curves.easeInOut);
      setState(() => currentPage--);
    }
  }

  bool _validatePage() {
    if (currentPage == 0) {
      if (fullNameController.text.isEmpty || phoneController.text.isEmpty || 
          barangayController.text.isEmpty || streetController.text.isEmpty) {
        _showError('Please fill in all fields');
        return false;
      }
    }
    return true;
  }

  Future<void> _submitBooking() async {
    final user = AuthService().currentUser!;
    
    double basePrice = switch (selectedService) {
      'Wash + Dry + Fold' => 180,
      'Wash + Dry' => 150,
      'Wash Only' => 65,
      'Spin + Dry + Fold' => 140,
      'Spin + Dry' => 100,
      _ => 35,
    };

    final total = basePrice * (loadKg / 3);

    final booking = Booking(
      id: 'FW-${DateTime.now().millisecondsSinceEpoch.toString().substring(5, 12)}',
      userId: user.id,
      customerName: fullNameController.text,
      phone: phoneController.text,
      barangay: barangayController.text,
      city: cityController.text,
      street: streetController.text,
      serviceType: selectedService!,
      detergent: selectedDetergent!,
      fabric: selectedFabric!,
      notes: notesController.text.isEmpty ? null : notesController.text,
      paymentMethod: selectedPayment!,
      loadKg: loadKg,
      totalPrice: total,
      createdAt: DateTime.now(),
      orderType: 'Delivery',
    );

    await BookingService().createBooking(booking);

    if (mounted) {
      Navigator.push(
        context,
        MaterialPageRoute(builder: (_) => BookingSuccessScreen(booking: booking)),
      );
    }
  }

  void _showError(String msg) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text(msg), backgroundColor: Colors.red, behavior: SnackBarBehavior.floating),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFE8E8E8),
      appBar: AppBar(
        backgroundColor: const Color(0xFFE8E8E8),
        elevation: 0,
        leading: currentPage > 0 
          ? IconButton(icon: const Icon(Icons.arrow_back, color: Colors.black), onPressed: _prevPage)
          : null,
        title: const Text('Booking', style: TextStyle(color: Colors.black, fontWeight: FontWeight.bold)),
        centerTitle: true,
      ),
      body: Column(
        children: [
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 40, vertical: 10),
            child: Row(
              children: [
                _buildProgressLine(currentPage >= 0, 'Details'),
                _buildProgressLine(currentPage >= 1, 'Service'),
                _buildProgressLine(currentPage >= 2, 'Confirm'),
              ],
            ),
          ),
          Expanded(
            child: PageView(
              controller: pageController,
              physics: const NeverScrollableScrollPhysics(),
              children: [
                _buildCustomerDetailsPage(),
                _buildBookingDetailsPage(),
                _buildReviewPage(),
              ],
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildProgressLine(bool isActive, String label) {
