class WavePainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = const Color(0xFF4A5FC1)
      ..style = PaintingStyle.fill;

    final path = Path();
    path.moveTo(size.width * 0.3, size.height * 0.4);
    path.quadraticBezierTo(size.width * 0.5, size.height * 0.2, size.width * 0.7, size.height * 0.4);
    path.quadraticBezierTo(size.width * 0.5, size.height * 0.6, size.width * 0.3, size.height * 0.4);
    canvas.drawPath(path, paint);

    final lightPaint = Paint()
      ..color = const Color(0xFF87CEEB)
      ..style = PaintingStyle.fill;
    
    final lightPath = Path();
    lightPath.moveTo(size.width * 0.35, size.height * 0.45);
    lightPath.quadraticBezierTo(size.width * 0.5, size.height * 0.3, size.width * 0.65, size.height * 0.45);
    lightPath.quadraticBezierTo(size.width * 0.5, size.height * 0.55, size.width * 0.35, size.height * 0.45);
    canvas.drawPath(lightPath, lightPaint);
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;
}

