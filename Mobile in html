        }

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            const userMenu = document.getElementById('user-menu');
            const dropdown = document.getElementById('user-dropdown');
            if (!userMenu.contains(e.target)) {
                dropdown.classList.add('hidden');
            }
        });

        // --- Auth Modal ---
        const authModal = document.getElementById('auth-modal');
        const authBackdrop = document.getElementById('auth-backdrop');
        const authPanel = document.getElementById('auth-panel');

        function openAuthModal(type) {
            authModal.classList.remove('hidden');
            setTimeout(() => {
                authBackdrop.classList.remove('opacity-0');
                authPanel.classList.remove('opacity-0', 'scale-95');
                authPanel.classList.add('opacity-100', 'scale-100');
            }, 10);
            switchAuthTab(type);
        }

        function closeAuthModal() {
            authBackdrop.classList.add('opacity-0');
            authPanel.classList.remove('opacity-100', 'scale-100');
            authPanel.classList.add('opacity-0', 'scale-95');
            setTimeout(() => authModal.classList.add('hidden'), 300);
        }

        function switchAuthTab(type) {
            const loginTab = document.getElementById('tab-login');
            const signupTab = document.getElementById('tab-signup');
            const loginForm = document.getElementById('login-form');
            const signupForm = document.getElementById('signup-form');
            const title = document.getElementById('auth-title');

            if (type === 'login') {
                loginTab.className = 'flex-1 py-4 text-center font-bold text-wave-600 border-b-2 border-wave-600 bg-wave-50/50';
                signupTab.className = 'flex-1 py-4 text-center font-bold text-slate-400 hover:text-slate-600 transition-colors';
                loginForm.classList.remove('hidden');
                signupForm.classList.add('hidden');
                title.textContent = 'Welcome Back';
            } else {
                signupTab.className = 'flex-1 py-4 text-center font-bold text-wave-600 border-b-2 border-wave-600 bg-wave-50/50';
                loginTab.className = 'flex-1 py-4 text-center font-bold text-slate-400 hover:text-slate-600 transition-colors';
                signupForm.classList.remove('hidden');
                loginForm.classList.add('hidden');
                title.textContent = 'Create Account';
            }
        }

        // --- Authentication ---
        function login() {
            const email = document.getElementById('login-email').value;
            const password = document.getElementById('login-password').value;
            
            if (!email || !password) {
                showToast('Please fill in all fields', 'error');
                return;
            }
            
            // Simulate login
            currentUser = {
                email: email,
                firstName: email.split('@')[0],
                lastName: 'User'
            };
            
            updateUIForUser();
            closeAuthModal();
            showToast('Welcome back! You are now logged in.');
        }

        function signup() {
            const firstName = document.getElementById('signup-firstname').value;
            const lastName = document.getElementById('signup-lastname').value;
            const email = document.getElementById('signup-email').value;
            const password = document.getElementById('signup-password').value;
            const terms = document.getElementById('terms').checked;
            
            if (!firstName || !lastName || !email || !password) {
                showToast('Please fill in all fields', 'error');
                return;
            }
            
            if (!terms) {
                showToast('Please accept the terms and conditions', 'error');
                return;
            }
            
            currentUser = { email, firstName, lastName };
            updateUIForUser();
            closeAuthModal();
            showToast('Account created successfully! Welcome to Fresh Wave.');
        }

        function logout() {
            currentUser = null;
            updateUIForUser();
            showToast('You have been logged out.');
            document.getElementById('user-dropdown').classList.add('hidden');
        }

        function updateUIForUser() {
            const authButtons = document.getElementById('auth-buttons');
            const userMenu = document.getElementById('user-menu');
            const mobileAuth = document.getElementById('mobile-auth-section');
            const mobileUser = document.getElementById('mobile-user-section');
            const mobileAvatar = document.getElementById('mobile-user-avatar-container');

            if (currentUser) {
                // Desktop
                authButtons.classList.add('hidden');
                userMenu.classList.remove('hidden');
                userMenu.classList.add('flex');
                
                // Mobile
                mobileAuth.classList.add('hidden');
                mobileUser.classList.remove('hidden');
                mobileAvatar.classList.remove('hidden');
                mobileAvatar.classList.add('block');
                
                // Update info
                const initials = currentUser.firstName.charAt(0) + currentUser.lastName.charAt(0);
                const fullName = `${currentUser.firstName} ${currentUser.lastName}`;
                
                document.getElementById('user-name').textContent = fullName;
                document.getElementById('user-avatar').textContent = initials;
                document.getElementById('dropdown-name').textContent = fullName;
                document.getElementById('dropdown-email').textContent = currentUser.email;
                
                document.getElementById('mobile-user-avatar').textContent = initials;
                document.getElementById('mobile-menu-name').textContent = fullName;
                document.getElementById('mobile-menu-email').textContent = currentUser.email;
                
                // Pre-fill booking
                document.getElementById('booking-firstname').value = currentUser.firstName;
                document.getElementById('booking-lastname').value = currentUser.lastName;
            } else {
                // Desktop
                authButtons.classList.remove('hidden');
                userMenu.classList.add('hidden');
                userMenu.classList.remove('flex');
                
                // Mobile
                mobileAuth.classList.remove('hidden');
                mobileUser.classList.add('hidden');
                mobileAvatar.classList.add('hidden');
                mobileAvatar.classList.remove('block');
                
                // Clear booking
                document.getElementById('booking-firstname').value = '';
                document.getElementById('booking-lastname').value = '';
            }
        }

        // --- Booking Modal ---
        const bookingModal = document.getElementById('booking-modal');
        const bookingBackdrop = document.getElementById('booking-backdrop');
        const bookingPanel = document.getElementById('booking-panel');

        function openBookingModal() {
            if (!currentUser) {
                openAuthModal('login');
                showToast('Please login to book a service', 'error');
                return;
            }
            bookingModal.classList.remove('hidden');
            setTimeout(() => {
                bookingBackdrop.classList.remove('opacity-0');
                bookingPanel.classList.remove('opacity-0', 'scale-95');
                bookingPanel.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeBookingModal() {
            bookingBackdrop.classList.add('opacity-0');
            bookingPanel.classList.remove('opacity-100', 'scale-100');
            bookingPanel.classList.add('opacity-0', 'scale-95');
            setTimeout(() => bookingModal.classList.add('hidden'), 300);
        }

        function submitBooking() {
            const address = document.getElementById('booking-address').value;
            const date = document.getElementById('booking-date').value;
            
            if (!address || !date) {
                showToast('Please fill in all required fields', 'error');
                return;
            }
            
            closeBookingModal();
            const orderId = 'FW-' + new Date().getFullYear() + '-' + Math.floor(100 + Math.random() * 900);
            showToast(`Booking confirmed! Order ID: ${orderId}`);
            
            setTimeout(() => {
                document.getElementById('track-input').value = orderId;
                trackOrder();
                document.getElementById('tracking').scrollIntoView({behavior: 'smooth'});
            }, 1500);
        }

        // --- Price Calculator ---
        function setService(type, rate) {
            currentServiceRate = rate;
            
            document.querySelectorAll('.calc-btn').forEach(btn => {
                btn.classList.remove('bg-wave-500', 'text-white', 'border-wave-500');
                btn.classList.add('bg-transparent', 'text-slate-300', 'border-slate-600');
            });
            
            const activeBtn = document.getElementById(`calc-${type}`);
            activeBtn.classList.remove('bg-transparent', 'text-slate-300', 'border-slate-600');
            activeBtn.classList.add('bg-wave-500', 'text-white', 'border-wave-500');
            
            calculatePrice();
        }

        document.getElementById('calc-slider').addEventListener('input', (e) => {
            document.getElementById('calc-weight-display').textContent = e.target.value + ' kg';
            calculatePrice();
        });

        function calculatePrice() {
            const weight = parseInt(document.getElementById('calc-slider').value);
            const delivery = document.getElementById('delivery-check').checked;
            let total = weight * currentServiceRate;
            if (delivery) total += 50;
            document.getElementById('calc-total').textContent = total;
        }

        function selectService(service) {
            if (service === 'wash') setService('wash', 45);
            if (service === 'express') setService('express', 90);
            document.getElementById('pricing').scrollIntoView({behavior: 'smooth'});
        }

        // --- Tracking ---
        function trackOrder() {
            const input = document.getElementById('track-input').value;
            const result = document.getElementById('tracking-result');
            
            if (!input) {
                showToast('Please enter an Order ID', 'error');
                return;
            }
            
            result.classList.remove('hidden');
            
            // Reset
            document.getElementById('progress-fill').style.width = '0%';
            [2, 3, 4].forEach(i => {
                document.getElementById(`step-${i}`).className = 'w-12 h-12 rounded-full bg-slate-200 text-slate-500 flex items-center justify-center z-10 ring-4 ring-white transition-all duration-500';
                document.getElementById(`text-${i}`).className = 'text-xs font-medium text-slate-500';
            });
            
            // Animate
            setTimeout(() => {
                const scenarios = [
                    { width: '10%', step: 1, msg: 'Your laundry has been received and is queued for processing.' },
                    { width: '40%', step: 2, msg: 'Your clothes are currently being washed with premium detergent.' },
                    { width: '70%', step: 3, msg: 'Drying and folding in progress. Almost ready!' },
                    { width: '100%', step: 4, msg: 'Your laundry is ready for pickup/delivery!' }
                ];
                
                const random = scenarios[Math.floor(Math.random() * scenarios.length)];
                
                document.getElementById('progress-fill').style.width = random.width;
                document.getElementById('status-message').textContent = random.msg;
                document.getElementById('res-id').textContent = '#' + input;
                
                for (let i = 2; i <= random.step; i++) {
                    document.getElementById(`step-${i}`).className = 'w-12 h-12 rounded-full bg-wave-500 text-white flex items-center justify-center z-10 ring-4 ring-white shadow-lg transition-all duration-500';
                    document.getElementById(`text-${i}`).className = 'text-xs font-bold text-wave-600';
                }
            }, 500);
        }

        // --- Toast ---
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toast-icon');
            const title = document.getElementById('toast-title');
            
            document.getElementById('toast-message').textContent = message;
            
            if (type === 'error') {
                icon.className = 'w-10 h-10 bg-red-500 rounded-full flex items-center justify-center flex-shrink-0';
                icon.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                title.textContent = 'Error';
                title.className = 'font-bold text-sm text-red-400';
            } else {
                icon.className = 'w-10 h-10 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0';
                icon.innerHTML = '<i class="fa-solid fa-check"></i>';
                title.textContent = 'Success';
                title.className = 'font-bold text-sm text-green-400';
            }
            
            toast.classList.remove('translate-y-24');
            setTimeout(() => toast.classList.add('translate-y-24'), 4000);
        }

        // --- GSAP Animations ---
        gsap.registerPlugin(ScrollTrigger);
        
        gsap.utils.toArray('.service-card').forEach((card, i) => {
            gsap.from(card, {
                scrollTrigger: { trigger: card, start: 'top 85%' },
                y: 50,
                opacity: 0,
                duration: 0.6,
                delay: i * 0.1
            });
        });

        // Close modals on backdrop click
        authBackdrop.addEventListener('click', closeAuthModal);
        bookingBackdrop.addEventListener('click', closeBookingModal);

    </script>
</body>
</html>
